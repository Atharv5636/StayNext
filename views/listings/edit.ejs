<% layout("/layout/boilerplate.ejs")%>
<body>
  <form action="/listings/<%=myListings._id%>?_method=PUT" method="POST">
    <div class="edit_form_container">
      <div class="edit_form">
        <div class="heading_form">
          <h2>Edit Listing</h2>
          <p>Update the details of your listing below:</p>
        </div>

        <div class="form_group">
          <label for="title">Title: </label>
          <input type="text" name="title" value="<%=myListings.title%>" />
        </div>
        <div class="form_group">
          <label for="description">Description: </label>
          <input
            type="text"
            name="description"
            value="<%=myListings.description%>"
          />
        </div>
        <div class="form_group">
          <label for="image">Image URL</label>
          <input type="text" name="image" value="<%=myListings.image.url%>" />
        </div>
        <div class="form_group">
          <label for="price">Price</label>
          <input type="text" name="price" value="<%=myListings.price%>" />
        </div>
        <div class="form_group">
          <label for="location">Location</label>
          <input type="text" name="location" value="<%=myListings.location%>" />
        </div>
        <div class="form_group">
          <label for="country">Country: </label>
          <input type="text" name="country" value="<%=myListings.country%>" />
        </div>

        <button>submit</button>
      </div>
    </div>
  </form>
</body>
